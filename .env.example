# MagnetBank Configuration
# ------------------------
# This file should be copied to '.env' at the PROJECT ROOT.
# Do NOT commit your '.env' file to version control.

# --- Hive Blockchain Settings ---
# URL of the Hive API node to connect to
HIVE_NODE=https://api.hive.blog

# Authorized Hive account for administrative actions (DMCA/Categories)
ADMIN_ACCOUNT=your_hive_account

# The block number to start scanning from if no progress is found in DB
GENISYS_BLOCK=74492600

# --- Database Settings ---
# Path to the SQLite database file relative to the project root
SQLITE_DB=magnetbank.db

# --- Flask Settings ---
# Optional: Set to 1 for development/debug mode
FLASK_DEBUG=1
